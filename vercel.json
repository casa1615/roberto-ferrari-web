{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://legalcrm-cyngbuug.manus.space/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
